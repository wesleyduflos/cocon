rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isMemberOf(householdId) {
      return isAuthenticated() &&
             request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    function isOwnerOf(householdId) {
      return isAuthenticated() &&
             request.auth.uid == get(/databases/$(database)/documents/households/$(householdId)).data.ownerId;
    }

    // Users : chacun voit/édite son propre profil
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;

      // Intégrations tierces (Google Calendar refresh token, etc.) — accès
      // strictement limité au propriétaire du compte. Les autres membres
      // du cocon n'ont JAMAIS accès à ces docs (contrairement aux tasks).
      match /integrations/{integrationId} {
        allow read, write: if request.auth.uid == userId;
      }

      // FCM tokens : pareil, propriétaire uniquement. Lectures par Cloud
      // Functions via le SDK Admin (qui bypasse les rules).
      match /fcmTokens/{tokenId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Invitations : un user authentifié peut lire une invitation dont il
    // connaît le token (sécurité par le secret = UUIDv4, 122 bits d'entropie).
    // Création réservée au membre du cocon ciblé. Update permis aux
    // authentifiés (pour marquer 'accepted' lors de l'acceptation).
    match /invitations/{token} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.invitedBy == request.auth.uid
                    && isMemberOf(request.resource.data.householdId);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated()
                    && resource.data.invitedBy == request.auth.uid;
    }

    // Invite codes courts (sprint 5) : 6 chars alphanumériques. Un user
    // authentifié peut lire un code dont il connaît la valeur exacte
    // (sécurité par obscurité — 32^6 = ~1 milliard de combinaisons,
    // suffisant pour un foyer perso). Create réservé aux membres du cocon
    // cible. Update (désactivation) par membres aussi.
    match /invite-codes/{code} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.createdBy == request.auth.uid
                    && isMemberOf(request.resource.data.householdId);
      allow update: if isAuthenticated()
                    && isMemberOf(resource.data.householdId);
      allow delete: if isAuthenticated()
                    && isMemberOf(resource.data.householdId);
    }

    // Households
    match /households/{householdId} {
      // On utilise `resource.data` (le doc en cours d'évaluation) plutôt que
      // `get()` pour autoriser les `list`/`query` operations (Firestore ne
      // supporte pas bien les `get()` récursifs sur le même doc pour les
      // queries — il refuse silencieusement le where-array-contains).
      allow read: if isAuthenticated() && request.auth.uid in resource.data.memberIds;
      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == request.auth.uid;
      // Owner : tous droits. Sinon, un user authentifié peut ajouter
      // SON propre uid à memberIds (pour accepter une invitation), sans
      // pouvoir modifier autre chose.
      allow update: if (isAuthenticated() && resource.data.ownerId == request.auth.uid)
                    || (
                      isAuthenticated()
                      && !(request.auth.uid in resource.data.memberIds)
                      && request.auth.uid in request.resource.data.memberIds
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                    );
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;

      // Sous-collection members : un user peut créer son propre doc member,
      // les autres opérations sont réservées aux membres du cocon.
      match /members/{memberId} {
        allow read: if isMemberOf(householdId);
        allow create: if isAuthenticated() && memberId == request.auth.uid;
        allow update, delete: if isOwnerOf(householdId) || memberId == request.auth.uid;
      }

      // Sous-collections génériques (tasks, shopping-items, etc.) :
      // lecture/écriture réservée aux membres du cocon.
      match /{collection}/{document=**} {
        allow read, write: if isMemberOf(householdId);
      }
    }
  }
}
