# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# netlify
.netlify/

# firebase
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
.runtimeconfig.json

# cloud functions build output
functions/lib/
functions/node_modules/

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.vscode/
.idea/

# Claude Code (session-local settings)
.claude/settings.local.json
